OPENAI_MODEL=gpt-5.4

SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
ALLOWED_SLACK_USER_IDS=
ALLOW_SHARED_ATTACH=0

CODEX_BIN=codex
CODEX_WORKDIR=/ssd/home/your_dir
CODEX_TIMEOUT_SECONDS=900
CODEX_SANDBOX=danger-full-access
CODEX_FULL_AUTO=0
CODEX_EXTRA_ARGS=
CODEX_SLACK_SESSION_STORE=/ssd/home/your_dir/codex-slack/.codex-slack-sessions.json
# CODEX_SLACK_INSTANCE_LOCK=/ssd/home/your_dir/codex-slack/.codex-slack.pid
CODEX_SLACK_WATCH_POLL_SECONDS=5
CODEX_PROGRESS_HEARTBEAT_SECONDS=300
CODEX_PROGRESS_POLL_SECONDS=15
# CODEX_SLACK_APP_SERVER_LINE_LIMIT_BYTES=33554432
